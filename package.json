{
  "name": "auth0-guardian-js",
  "version": "1.3.3",
  "description": "Interface",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "jwt-decode": "^4.0.0",
    "socket.io-client": "^4.8.1",
    "superagent": "^10.2.3",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "auth0-style": "github:auth0/javascript",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.32.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mocha": "^11.1.0",
    "eslint-plugin-react": "^7.37.5",
    "jsonwebtoken": "^9.0.1",
    "mocha": "^11.7.1",
    "mockuire": "^2.1.0",
    "pem": "^1.14.8",
    "proxyquire": "^2.1.3",
    "semver": "^6.3.1",
    "sinon": "^21.0.0",
    "watch": "^0.13.0",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.1"
  },
  "scripts": {
    "test": "mocha",
    "test:recursive": "mocha --recursive test",
    "build": "webpack --config webpack.config.js",
    "build:clean": "rm -rf ./dist && mkdir dist",
    "dist": "npm run build:clean && npm run build",
    "lint": "npm run eslint",
    "watch:build": "watch 'npm run build' --ignoreDirectoryPattern=/dist/",
    "watch:lint": "watch 'npm run eslint'",
    "eslint": "eslint .",
    "eslintfix": "eslint --fix .",
    "prepublish": "npm run build",
    "serve:https": "node ./tools/serve.js",
    "dev": "concurrently \"npm run watch:build\" \"npm run serve:https\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auth0/auth0-guardian.js.git"
  },
  "keywords": [
    "Guardian",
    "Guadian",
    "Headless",
    "Auth0",
    "Auth0",
    "Guardian"
  ],
  "author": "Auth0",
  "license": "MIT",
  "bugs": {
